# Google AI Studio / Gemini API
# Create this in Google AI Studio, then keep the real value in .env.local.
GEMINI_API_KEY= # Go to Google AI Studio, create a Gemini API key, and put it here. Keep the real value in .env.local.
GEMINI_MODEL=gemini-2.5-flash

# Oracle via SSH tunnel. Start the tunnel before running DB-backed routes.
ORACLE_USER=pin
ORACLE_PASSWORD=pin
ORACLE_CONNECT_STRING=localhost:1521/orclpdb
ORACLE_POOL_MIN=0
ORACLE_POOL_MAX=4
ORACLE_POOL_INCREMENT=1

# Optional: one read-only SQL statement included as extra context for AI answers.
# Keep this SELECT-only and small.
NEXTAI_ORACLE_CONTEXT_SQL=

# SSH tunnel helper script settings.
OCI_SSH_USER=cloud-user
OCI_SSH_HOST= # Put in your OCI server IP address here
OCI_SSH_KEY= # Put your private key path here, e.g. /home/user/.ssh/id_rsa
OCI_LOCAL_PORT=1521
OCI_REMOTE_HOST=localhost
OCI_REMOTE_PORT=1521
